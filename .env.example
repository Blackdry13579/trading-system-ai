# ============================================================
# GOLDBOT — Variables d'environnement
# Copier ce fichier en .env et remplir les vraies valeurs
# NE JAMAIS committer .env sur GitHub
# ============================================================

# ── MetaTrader 5 (Exness Demo) ───────────────────────────
MT5_LOGIN=TON_LOGIN_MT5
MT5_PASSWORD=TON_MOT_DE_PASSE
MT5_SERVER=Exness-MT5Trial9

# ── Telegram ─────────────────────────────────────────────
TELEGRAM_TOKEN=TON_TOKEN_BOT
TELEGRAM_CHAT_ID=TON_CHAT_ID

# ── FRED API (données macro gratuites) ───────────────────
# Clé gratuite sur : https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=TA_CLE_FRED

# ── MyFxBook (sentiment retail XAU/USD) ──────────────────
MYFXBOOK_EMAIL=TON_EMAIL_MYFXBOOK
MYFXBOOK_PASSWORD=TON_MOT_DE_PASSE_MYFXBOOK

# ── DeepSeek NIM local (optionnel — nécessite GPU) ───────
NIM_BASE_URL=http://localhost:8000/v1
NIM_API_KEY=nim-local-key

# ── Paramètres trading ───────────────────────────────────
TRADING_MODE=paper
MAX_RISK_PER_TRADE=0.02
MAX_DAILY_DRAWDOWN=0.05
MIN_SIGNAL_SCORE=52
